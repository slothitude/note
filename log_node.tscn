[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://log_node.gd" id="1_script"]

[node name="LogNode" type="GraphNode"]
custom_minimum_size = Vector2(220, 200)
offset_right = 220.0
offset_bottom = 250.0
title = "Log"
script = ExtResource("1_script")

[node name="InputLabel" type="Label" parent="."]
layout_mode = 2
text = "← Value"

[node name="LogView" type="RichTextLabel" parent="."]
unique_name_in_owner = true
custom_minimum_size = Vector2(200, 120)
layout_mode = 2
bbcode_enabled = true
scroll_following = true
text = ""

[node name="CountLabel" type="Label" parent="."]
unique_name_in_owner = true
layout_mode = 2
text = "0 entries"

[node name="MaxLabel" type="Label" parent="."]
layout_mode = 2
text = "Max entries"

[node name="MaxSpin" type="SpinBox" parent="."]
unique_name_in_owner = true
layout_mode = 2
min_value = 1.0
max_value = 1000.0
value = 50.0

[node name="ClearButton" type="Button" parent="."]
layout_mode = 2
text = "Clear"

[node name="DeleteButton" type="Button" parent="."]
layout_mode = 2
text = "Delete"

[connection signal="pressed" from="ClearButton" to="." method="_on_clear"]
[connection signal="pressed" from="DeleteButton" to="." method="_on_delete_pressed"]
