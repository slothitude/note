[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://file_watch_node.gd" id="1_script"]

[node name="FileWatchNode" type="GraphNode"]
custom_minimum_size = Vector2(220, 160)
offset_right = 220.0
offset_bottom = 180.0
title = "File Watch"
script = ExtResource("1_script")

[node name="PathLabel" type="Label" parent="."]
layout_mode = 2
text = "File Path"

[node name="PathEdit" type="LineEdit" parent="."]
unique_name_in_owner = true
layout_mode = 2
placeholder_text = "path/to/file.txt"

[node name="IntervalLabel" type="Label" parent="."]
layout_mode = 2
text = "Interval (s)"

[node name="IntervalSpin" type="SpinBox" parent="."]
unique_name_in_owner = true
layout_mode = 2
min_value = 0.5
max_value = 60.0
step = 0.5
value = 2.0

[node name="StatusLabel" type="Label" parent="."]
unique_name_in_owner = true
layout_mode = 2
text = "Stopped"

[node name="ToggleButton" type="Button" parent="."]
layout_mode = 2
text = "Start/Stop"

[node name="DeleteButton" type="Button" parent="."]
layout_mode = 2
text = "Delete"

[connection signal="pressed" from="ToggleButton" to="." method="_on_toggle_watching"]
[connection signal="pressed" from="DeleteButton" to="." method="_on_delete_pressed"]
