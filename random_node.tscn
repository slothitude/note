[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://random_node.gd" id="1_script"]

[node name="RandomNode" type="GraphNode"]
custom_minimum_size = Vector2(200, 120)
offset_right = 200.0
offset_bottom = 120.0
title = "Random"
script = ExtResource("1_script")

[node name="MinLabel" type="Label" parent="."]
layout_mode = 2
text = "Min"

[node name="MaxLabel" type="Label" parent="."]
layout_mode = 2
text = "Max"

[node name="ModeLabel" type="Label" parent="."]
layout_mode = 2
text = "Mode"

[node name="ModeOption" type="OptionButton" parent="."]
unique_name_in_owner = true
layout_mode = 2

[node name="ResultLabel" type="Label" parent="."]
unique_name_in_owner = true
layout_mode = 2
text = "—"

[node name="DeleteButton" type="Button" parent="."]
layout_mode = 2
text = "Delete"

[connection signal="item_selected" from="ModeOption" to="." method="_on_mode_selected"]
[connection signal="pressed" from="DeleteButton" to="." method="_on_delete_pressed"]
