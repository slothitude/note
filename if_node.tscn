[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://if_node.gd" id="1_script"]

[node name="IfNode" type="GraphNode"]
custom_minimum_size = Vector2(160, 100)
offset_right = 160.0
offset_bottom = 100.0
title = "If"
script = ExtResource("1_script")

[node name="ConditionLabel" type="Label" parent="."]
layout_mode = 2
text = "Condition"

[node name="DataLabel" type="Label" parent="."]
layout_mode = 2
text = "Data"

[node name="Result" type="Label" parent="."]
unique_name_in_owner = true
layout_mode = 2
text = "→ false"

[node name="Spacer" type="Control" parent="."]
custom_minimum_size = Vector2(0, 20)
layout_mode = 2

[node name="DeleteButton" type="Button" parent="."]
unique_name_in_owner = true
layout_mode = 2
text = "Delete"

[connection signal="pressed" from="DeleteButton" to="." method="_on_delete_pressed"]
