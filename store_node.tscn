[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://store_node.gd" id="1_script"]

[node name="StoreNode" type="GraphNode"]
custom_minimum_size = Vector2(220, 160)
offset_right = 220.0
offset_bottom = 200.0
title = "Store"
script = ExtResource("1_script")

[node name="ModeOption" type="OptionButton" parent="."]
unique_name_in_owner = true
layout_mode = 2
item_count = 5
popup/item_0/text = "GET"
popup/item_1/text = "SET"
popup/item_2/text = "DELETE"
popup/item_3/text = "LIST"
popup/item_4/text = "CLEAR"

[node name="KeyLabel" type="Label" parent="."]
layout_mode = 2
text = "Key"

[node name="KeyEdit" type="LineEdit" parent="."]
unique_name_in_owner = true
layout_mode = 2
placeholder_text = "key"

[node name="ResultLabel" type="Label" parent="."]
unique_name_in_owner = true
layout_mode = 2
text = "—"

[node name="DeleteButton" type="Button" parent="."]
layout_mode = 2
text = "Delete"

[connection signal="item_selected" from="ModeOption" to="." method="_on_mode_selected"]
[connection signal="pressed" from="DeleteButton" to="." method="_on_delete_pressed"]
