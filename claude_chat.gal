# Claude Chat Pipeline
# 1. Set your API key in the "headers" notepad (replace YOUR_KEY)
# 2. Edit the "prompt" in the body notepad
# 3. Trigger fires the request, response lands in "output"
node body notepad at 0 0
set body.text {"model":"claude-sonnet-4-20250514","max_tokens":1024,"messages":[{"role":"user","content":"What is GDScript?"}]}

node headers notepad at 0 150
set headers.text x-api-key: YOUR_KEY\nanthropic-version: 2023-06-01

node req http at 300 0
set req.url https://api.anthropic.com/v1/messages
set req.method POST
wire body.out -> req.body
wire headers.out -> req.headers

node parse json at 550 0
set parse.path content.0.text
wire req.response -> parse.json

node output notepad at 800 0
wire parse.result -> output.set

node errlog notepad at 800 150
wire parse.error -> errlog.set
wire req.error -> errlog.append

trigger req
