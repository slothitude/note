[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://pie_chart_node.gd" id="1_script"]

[node name="PieChartNode" type="GraphNode"]
custom_minimum_size = Vector2(280, 280)
offset_right = 280.0
offset_bottom = 280.0
title = "Pie Chart"
script = ExtResource("1_script")

[node name="DataLabel" type="Label" parent="."]
layout_mode = 2
text = "Data"

[node name="TitleEdit" type="LineEdit" parent="."]
unique_name_in_owner = true
layout_mode = 2
placeholder_text = "Chart title..."

[node name="ChartPanel" type="Panel" parent="."]
unique_name_in_owner = true
custom_minimum_size = Vector2(260, 200)
layout_mode = 2

[node name="Spacer" type="Control" parent="."]
custom_minimum_size = Vector2(0, 10)
layout_mode = 2

[node name="DeleteButton" type="Button" parent="."]
layout_mode = 2
text = "Delete"

[connection signal="draw" from="ChartPanel" to="." method="_on_chart_draw"]
[connection signal="text_changed" from="TitleEdit" to="." method="_on_title_changed"]
[connection signal="pressed" from="DeleteButton" to="." method="_on_delete_pressed"]
