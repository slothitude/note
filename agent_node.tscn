[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://agent_node.gd" id="1_script"]

[node name="AgentNode" type="GraphNode"]
custom_minimum_size = Vector2(240, 200)
offset_right = 240.0
offset_bottom = 200.0
title = "Agent"
script = ExtResource("1_script")

[node name="PromptLabel" type="Label" parent="."]
layout_mode = 2
text = "Prompt"

[node name="SystemLabel" type="Label" parent="."]
layout_mode = 2
text = "System"

[node name="UrlLabel" type="Label" parent="."]
layout_mode = 2
text = "URL"

[node name="ResultLabel" type="Label" parent="."]
layout_mode = 2
text = "Result"

[node name="LogLabel" type="Label" parent="."]
layout_mode = 2
text = "Log"

[node name="ModelLabel" type="Label" parent="."]
layout_mode = 2
text = "Model"

[node name="ModelEdit" type="LineEdit" parent="."]
unique_name_in_owner = true
layout_mode = 2
text = "llama3.2"
placeholder_text = "Model name"

[node name="TurnsLabel" type="Label" parent="."]
layout_mode = 2
text = "Max Turns"

[node name="TurnsSpin" type="SpinBox" parent="."]
unique_name_in_owner = true
layout_mode = 2
min_value = 1.0
max_value = 10.0
value = 5.0

[node name="StatusLabel" type="Label" parent="."]
unique_name_in_owner = true
layout_mode = 2
text = "Ready"

[node name="RunButton" type="Button" parent="."]
layout_mode = 2
text = "Run"

[node name="StopButton" type="Button" parent="."]
layout_mode = 2
text = "Stop"

[node name="DeleteButton" type="Button" parent="."]
layout_mode = 2
text = "Delete"

[connection signal="pressed" from="RunButton" to="." method="_on_run_pressed"]
[connection signal="pressed" from="StopButton" to="." method="_on_stop_pressed"]
[connection signal="pressed" from="DeleteButton" to="." method="_on_delete_pressed"]
