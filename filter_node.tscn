[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://filter_node.gd" id="1_script"]

[node name="FilterNode" type="GraphNode"]
custom_minimum_size = Vector2(220, 180)
offset_right = 220.0
offset_bottom = 180.0
title = "Filter"
script = ExtResource("1_script")

[node name="InputLabel" type="Label" parent="."]
layout_mode = 2
text = "Input"

[node name="ParamLabel" type="Label" parent="."]
layout_mode = 2
text = "Param"

[node name="ModeLabel" type="Label" parent="."]
layout_mode = 2
text = "Mode"

[node name="ModeOption" type="OptionButton" parent="."]
unique_name_in_owner = true
layout_mode = 2

[node name="ParamEdit" type="LineEdit" parent="."]
unique_name_in_owner = true
layout_mode = 2
placeholder_text = "filter text / count / N"

[node name="ResultLabel" type="Label" parent="."]
unique_name_in_owner = true
layout_mode = 2
text = "—"

[node name="DeleteButton" type="Button" parent="."]
layout_mode = 2
text = "Delete"

[connection signal="item_selected" from="ModeOption" to="." method="_on_mode_selected"]
[connection signal="text_changed" from="ParamEdit" to="." method="_on_param_changed"]
[connection signal="pressed" from="DeleteButton" to="." method="_on_delete_pressed"]
