# Ollama Tool Call Pipeline
# Uses structured JSON output format for reliable parsing
# Edit the "prompt" in the body notepad, then trigger
node body notepad at 0 0
set body.text {"model":"llama3.2","messages":[{"role":"user","content":"What is 2+2?"}],"stream":false,"format":{"type":"object","properties":{"answer":{"type":"integer"}},"required":["answer"]}}

node req http at 300 0
set req.url http://localhost:11434/api/chat
set req.method POST
wire body.out -> req.body

node parse json at 550 0
set parse.path message.content
wire req.response -> parse.json

node extract json at 800 0
set extract.path answer
wire parse.result -> extract.json

node output notepad at 1050 0
wire extract.result -> output.set

node errlog notepad at 1050 150
wire extract.error -> errlog.set
wire parse.error -> errlog.append
wire req.error -> errlog.append

trigger req
