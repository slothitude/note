[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://binary_node.gd" id="1_script"]

[node name="BinaryNode" type="GraphNode"]
custom_minimum_size = Vector2(150, 80)
offset_right = 150.0
offset_bottom = 80.0
title = "Binary"
script = ExtResource("1_script")

[node name="ToggleBtn" type="Button" parent="."]
unique_name_in_owner = true
layout_mode = 2
text = "false"

[node name="DeleteButton" type="Button" parent="."]
unique_name_in_owner = true
layout_mode = 2
text = "Delete"

[connection signal="pressed" from="ToggleBtn" to="." method="_on_toggle_pressed"]
[connection signal="pressed" from="DeleteButton" to="." method="_on_delete_pressed"]
