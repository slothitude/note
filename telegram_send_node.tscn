[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://telegram_send_node.gd" id="1_script"]

[node name="TelegramSendNode" type="GraphNode"]
custom_minimum_size = Vector2(220, 160)
offset_right = 220.0
offset_bottom = 200.0
title = "Telegram Send"
script = ExtResource("1_script")

[node name="TokenLabel" type="Label" parent="."]
layout_mode = 2
text = "Token"

[node name="TokenEdit" type="LineEdit" parent="."]
unique_name_in_owner = true
layout_mode = 2
placeholder_text = "Bot Token"

[node name="ChatLabel" type="Label" parent="."]
layout_mode = 2
text = "Chat ID"

[node name="ChatEdit" type="LineEdit" parent="."]
unique_name_in_owner = true
layout_mode = 2
placeholder_text = "Chat ID"

[node name="MessageLabel" type="Label" parent="."]
layout_mode = 2
text = "Message"

[node name="StatusLabel" type="Label" parent="."]
unique_name_in_owner = true
layout_mode = 2
text = "Ready"

[node name="SendButton" type="Button" parent="."]
layout_mode = 2
text = "Send"

[node name="DeleteButton" type="Button" parent="."]
layout_mode = 2
text = "Delete"

[connection signal="pressed" from="SendButton" to="." method="_on_send"]
[connection signal="pressed" from="DeleteButton" to="." method="_on_delete_pressed"]
