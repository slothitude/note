[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://pc_node.gd" id="1_script"]
[ext_resource type="Texture2D" path="res://pc_icon.png" id="2_icon"]

[sub_resource type="StyleBoxTexture" id="StyleBoxTexture_panel"]
texture = ExtResource("2_icon")

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_titlebar"]
bg_color = Color(0, 0, 0, 1)
corner_radius_top_left = 10
corner_radius_top_right = 10

[node name="PCNode" type="GraphNode"]
offset_position = Vector2(0, 0)
size = Vector2(300, 300)
custom_minimum_size = Vector2(300, 300)
title = "PC"
theme_override_styles/panel = SubResource("StyleBoxTexture_panel")
theme_override_styles/titlebar = SubResource("StyleBoxFlat_titlebar")
script = ExtResource("1_script")

[node name="Increment" type="Label" parent="."]
layout_mode = 2
text = "Increment"

[node name="Restart" type="Label" parent="."]
layout_mode = 2
text = "Restart"

[node name="Jump" type="Label" parent="."]
layout_mode = 2
text = "Jump"

[node name="CountLabel" type="Label" parent="."]
unique_name_in_owner = true
layout_mode = 2
text = "Count: 0"

[node name="Out0" type="Label" parent="."]
layout_mode = 2
text = "→ 0"

[node name="Out1" type="Label" parent="."]
layout_mode = 2
text = "→ 1"

[node name="Out2" type="Label" parent="."]
layout_mode = 2
text = "→ 2"

[node name="Out3" type="Label" parent="."]
layout_mode = 2
text = "→ 3"

[node name="Out4" type="Label" parent="."]
layout_mode = 2
text = "→ 4"

[node name="Out5" type="Label" parent="."]
layout_mode = 2
text = "→ 5"

[node name="MaxSpin" type="SpinBox" parent="."]
unique_name_in_owner = true
layout_mode = 2
min_value = 1.0
max_value = 6.0
value = 6.0

[node name="DeleteButton" type="Button" parent="."]
unique_name_in_owner = true
layout_mode = 2
text = "Delete"

[connection signal="pressed" from="DeleteButton" to="." method="_on_delete_pressed"]
