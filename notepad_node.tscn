[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://notepad_node.gd" id="1_script"]

[node name="NotepadNode" type="GraphNode"]
offset_position = Vector2(0, 0)
size = Vector2(200, 80)
title = "Notepad"
script = ExtResource("1_script")

[node name="Preview" type="Label" parent="."]
unique_name_in_owner = true
layout_mode = 2
text = "(empty)"
autowrap_mode = 2

[node name="OpenButton" type="Button" parent="."]
unique_name_in_owner = true
layout_mode = 2
text = "Open"

[connection signal="pressed" from="OpenButton" to="." method="_on_open_pressed"]
