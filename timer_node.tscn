[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://timer_node.gd" id="1_script"]

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_titlebar"]
bg_color = Color(0, 0, 0, 1)
corner_radius_top_left = 10
corner_radius_top_right = 10

[node name="TimerNode" type="GraphNode"]
custom_minimum_size = Vector2(200, 200)
offset_right = 200.0
offset_bottom = 150.0
title = "Timer"
theme_override_styles/titlebar = SubResource("StyleBoxFlat_titlebar")
script = ExtResource("1_script")

[node name="PromptLabel" type="Label" parent="."]
layout_mode = 2
text = "← Prompt"

[node name="StartLabel" type="Label" parent="."]
layout_mode = 2
text = "← Start"

[node name="IntervalLabel" type="Label" parent="."]
layout_mode = 2
text = "← Interval"

[node name="ModeOption" type="OptionButton" parent="."]
unique_name_in_owner = true
layout_mode = 2

[node name="CountSpin" type="SpinBox" parent="."]
unique_name_in_owner = true
layout_mode = 2
min_value = 1.0
max_value = 1000.0
value = 3.0

[node name="StatusLabel" type="Label" parent="."]
unique_name_in_owner = true
layout_mode = 2
text = "Stopped"

[node name="DeleteButton" type="Button" parent="."]
layout_mode = 2
text = "Delete"

[connection signal="item_selected" from="ModeOption" to="." method="_on_mode_changed"]
[connection signal="pressed" from="DeleteButton" to="." method="_on_delete_pressed"]
