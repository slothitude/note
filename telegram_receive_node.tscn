[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://telegram_receive_node.gd" id="1_script"]

[node name="TelegramReceiveNode" type="GraphNode"]
custom_minimum_size = Vector2(220, 160)
offset_right = 220.0
offset_bottom = 200.0
title = "Telegram Receive"
script = ExtResource("1_script")

[node name="TokenLabel" type="Label" parent="."]
layout_mode = 2
text = "Token"

[node name="TokenEdit" type="LineEdit" parent="."]
unique_name_in_owner = true
layout_mode = 2
placeholder_text = "Bot Token"

[node name="IntervalLabel" type="Label" parent="."]
layout_mode = 2
text = "Interval (s)"

[node name="IntervalSpin" type="SpinBox" parent="."]
unique_name_in_owner = true
layout_mode = 2
min_value = 1.0
max_value = 60.0
value = 3.0

[node name="StatusLabel" type="Label" parent="."]
unique_name_in_owner = true
layout_mode = 2
text = "Stopped"

[node name="ToggleButton" type="Button" parent="."]
layout_mode = 2
text = "Start/Stop"

[node name="DeleteButton" type="Button" parent="."]
layout_mode = 2
text = "Delete"

[connection signal="pressed" from="ToggleButton" to="." method="_on_toggle_polling"]
[connection signal="pressed" from="DeleteButton" to="." method="_on_delete_pressed"]
