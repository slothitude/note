[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://switch_node.gd" id="1_script"]

[node name="SwitchNode" type="GraphNode"]
custom_minimum_size = Vector2(200, 120)
offset_right = 200.0
offset_bottom = 120.0
title = "Switch"
script = ExtResource("1_script")

[node name="ValueLabel" type="Label" parent="."]
layout_mode = 2
text = "Value"

[node name="CasesLabel" type="Label" parent="."]
layout_mode = 2
text = "Cases (comma-sep)"

[node name="CaseEdit" type="LineEdit" parent="."]
unique_name_in_owner = true
layout_mode = 2
placeholder_text = "a,b,c"

[node name="DefaultLabel" type="Label" parent="."]
layout_mode = 2
text = "Default"

[node name="Case0Label" type="Label" parent="."]
layout_mode = 2
text = "Case 0"

[node name="Case1Label" type="Label" parent="."]
layout_mode = 2
text = "Case 1"

[node name="Case2Label" type="Label" parent="."]
layout_mode = 2
text = "Case 2"

[node name="DeleteButton" type="Button" parent="."]
layout_mode = 2
text = "Delete"

[connection signal="text_changed" from="CaseEdit" to="." method="_on_cases_changed"]
[connection signal="pressed" from="DeleteButton" to="." method="_on_delete_pressed"]
