[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://math_node.gd" id="1_script"]

[node name="MathNode" type="GraphNode"]
custom_minimum_size = Vector2(300, 300)
offset_right = 300.0
offset_bottom = 150.0
title = "Math"
script = ExtResource("1_script")

[node name="LabelA" type="Label" parent="."]
layout_mode = 2
text = "A"

[node name="LabelB" type="Label" parent="."]
layout_mode = 2
text = "B"

[node name="ModeOption" type="OptionButton" parent="."]
unique_name_in_owner = true
layout_mode = 2

[node name="Result" type="Label" parent="."]
unique_name_in_owner = true
layout_mode = 2
text = "0"

[node name="Spacer" type="Control" parent="."]
custom_minimum_size = Vector2(0, 20)
layout_mode = 2

[node name="DeleteButton" type="Button" parent="."]
unique_name_in_owner = true
layout_mode = 2
text = "Delete"

[connection signal="item_selected" from="ModeOption" to="." method="_on_mode_changed"]
[connection signal="pressed" from="DeleteButton" to="." method="_on_delete_pressed"]
